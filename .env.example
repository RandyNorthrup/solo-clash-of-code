# Environment variables for Solo Clash of Code.
# Copy to `.env` and adjust as needed. No repository secrets are required.

# Judge0 REST API endpoint.
#
# Development: used only by the Vite dev proxy (vite.config.ts). The proxy
#   routes /judge0/* to this URL, so the browser never calls Judge0 directly.
#   Defaults to http://localhost:2358 when unset.
#
# Production (npm run build): inlined at build time by Vite. The browser calls
#   this URL directly, so Judge0 must be reachable over HTTPS and must allow
#   CORS from your app's origin. Unset → falls back to /judge0 (broken in
#   production — the app will show "execution offline").
VITE_JUDGE0_URL=http://localhost:2358

# Judge0 base URL used by scripts/verify-judge0.mjs (live verification).
# Optional — defaults to http://localhost:2358 when unset.
JUDGE0_URL=http://localhost:2358

# OpenAI Responses API base URL.
#
# Development: ignored by the app; Vite proxies /openai/* to
#   https://api.openai.com so the browser can test the user-entered key locally.
#
# Production (npm run build): inlined at build time by Vite. Use a trusted
#   OpenAI-compatible proxy if direct browser calls are blocked by CORS.
#   The API key is entered in Account Setup, not stored in env files.
VITE_OPENAI_BASE_URL=https://api.openai.com

# Optional model override for AI puzzle generation.
# Defaults to gpt-5.5.
VITE_OPENAI_MODEL=gpt-5.5
